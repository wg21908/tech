set postmaster <Gmail email username>

# Log file for debugging fetchmail operations
set logfile /home/<USER>/.fetchmail.log

# Run in daemon mode: check every 5 minutes (300 seconds)
set daemon 300

# Use secure connection and certificate checking
poll imap.gmail.com protocol IMAP:
    user "<Gmail email username>@gmail.com" password "<Google App Password without spaces>"
    ssl
    sslcertck
    sslcertpath /etc/ssl/certs
    # Deliver mail to procmail for local delivery and filtering
    mda "/usr/bin/procmail -d <Linux username receiving email>"
    # Only retrieve unseen mail, leave seen messages on the server
    keep

